{
  "name": "mrmallorcagolf",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "check:text": "node scripts/check-text-corruption.js",
    "check:offers": "node --no-warnings scripts/check-offers-consistency.js",
    "check:content": "npm run check:text && npm run check:offers && npm run check:locale && npm run check:shared-locale",
    "check:locale": "node scripts/check-locale-content.js",
    "check:locale-leaks": "node scripts/check-locale-english-leaks.js",
    "check:shared-locale": "node scripts/check-shared-locale-fallbacks.js",
    "check:guide-locale-leaks": "node scripts/check-guide-locale-english-leaks.js",
    "check:i18n-release": "node scripts/locale-release-check.js",
    "check:ready": "npm run check:content && npm run check:i18n-release && npm run build"
  },
  "dependencies": {
    "next": "^14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "sharp": "^0.34.5"
  }
}
